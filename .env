# ====================================
# Zonix Eats - FRONTEND CONFIGURATION
# ====================================

# Backend API URLs (producción: usar API_URL_PROD)
API_URL_LOCAL=http://192.168.27.12:8000
API_URL_PROD=https://eats.aiblockweb.com

# Tiempo real: solo Pusher (no WebSocket/Laravel Echo)
# WS_URL_* y ECHO_* no se usan; se mantienen comentados por compatibilidad.
# WS_URL_LOCAL=ws://192.168.27.12:6001
# WS_URL_PROD=wss://eats.aiblockweb.com

# App Information
APP_NAME=Zonix Eats
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1

# Timeout Configuration (milliseconds)
CONNECTION_TIMEOUT=30000
RECEIVE_TIMEOUT=30000
REQUEST_TIMEOUT=30000

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Broadcasting: Pusher (ver PUSHER_*). No Echo/WebSocket.
# ECHO_APP_ID=zonix-eats-app
# ECHO_KEY=zonix-eats-key
ENABLE_WEBSOCKETS=false

# Debug: en producción usar false. Ver docs/ENV_VARIABLES.md
DEBUG_MODE=true
ENABLE_LOGGING=true

# Pusher (producción)
PUSHER_APP_KEY=bbcdf6aa58188e699d64
PUSHER_APP_CLUSTER=sa1
ENABLE_PUSHER=true


# App Domain y contacto (producción)
APP_DOMAIN=eats.aiblockweb.com
CONTACT_EMAIL=contact@eats.aiblockweb.com

# --- Variables de PRUEBAS/DEMO: NO usar en producción. Ver docs/ENV_VARIABLES.md ---
# PUSHER_AUTH_ENDPOINT no se usa (se arma con API_URL + /api/broadcasting/auth)
# API_URL_LOCAL, API_URL_TEST, APP_DOMAIN_LOCAL: solo desarrollo
# API_URL_TEST=https://test.eats.aiblockweb.com
# APP_DOMAIN_LOCAL=192.168.27.12

# Opcionales: tienen default en app_config.dart (mapas, timeouts, paginación, delivery fee)
# DEFAULT_DELIVERY_FEE=2.50
# OSM_TILE_URL=...
# NOMINATIM_REVERSE_URL=...
# NOMINATIM_SEARCH_URL=...
# GOOGLE_MAPS_DIR_URL=...
# GOOGLE_MAPS_SEARCH_URL=...
# GOOGLE_MAPS_POINT_URL=...
# OPENSTREETMAP_VIEW_URL=...
# WHATSAPP_BASE_URL=...
# GOOGLE_GEN_AI_* no referenciadas en lib/
