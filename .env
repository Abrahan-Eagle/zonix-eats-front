# Zonix Glasses — Frontend (local)
ENVIRONMENT=development
API_URL_LOCAL=http://127.0.0.1:8000
API_URL_PROD=
APP_NAME="Zonix Glasses"
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1
CONNECTION_TIMEOUT=30000
RECEIVE_TIMEOUT=30000
REQUEST_TIMEOUT=30000
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
ENABLE_WEBSOCKETS=false
ENABLE_PUSHER=false
PUSHER_APP_KEY=
PUSHER_APP_CLUSTER=mt1
GOOGLE_MAPS_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
APP_DOMAIN=
CONTACT_EMAIL=
DEBUG_MODE=true
ENABLE_LOGGING=true
