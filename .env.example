# ====================================
# Zonix Eats - FRONTEND CONFIGURATION
# Copiar a .env y completar valores. Nada debe quedar hardcodeado en código.
# ====================================

# Environment: development | local | staging | test | production (afecta APP_LINK_BASE_* si no usas APP_LINK_BASE)
ENVIRONMENT=development

# Backend API URLs (obligatorios; sin /api al final)
# Ejemplos por entorno (ajusta IP/puerto y dominios a los tuyos reales):
#   Local/LAN:  http://192.168.27.12:8000
#   Test:       https://test.eats.aiblockweb.com (u otro host cuando exista)
#   Producción: https://eats.aiblockweb.com
API_URL_LOCAL=
API_URL_PROD=

# Opcional: override único para API (si se define, ignora _LOCAL/_PROD)
# API_URL=

# WebSocket (legacy; tiempo real usa Pusher)
# WS_URL_LOCAL=
# WS_URL_PROD=

# App
APP_NAME=Zonix Eats
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1

# Timeouts (ms)
CONNECTION_TIMEOUT=30000
RECEIVE_TIMEOUT=30000
REQUEST_TIMEOUT=30000

# Reintentos
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000

# Paginación
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Broadcasting
ENABLE_WEBSOCKETS=false
ENABLE_PUSHER=true

# Pusher Channels (obligatorios si ENABLE_PUSHER=true)
PUSHER_APP_KEY=
PUSHER_APP_CLUSTER=mt1

# Opcional: endpoint de auth Pusher (si no se define, se usa API_URL + /api/broadcasting/auth)
# PUSHER_AUTH_ENDPOINT=

# Google Maps (opcional)
GOOGLE_MAPS_API_KEY=

# Firebase (opcional, notificaciones push)
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Dominio / contacto (opcional)
APP_DOMAIN=
CONTACT_EMAIL=

# --- Enlaces públicos al compartir QR de comercio (HTTPS …/r/{commerceId}) ---
# El QR generado en la app sigue siendo siempre: zonix://restaurant/{id} (no depende del servidor).
# Estas variables solo afectan el texto/enlace HTTPS al pulsar "Compartir" y documentación web.
# Los host de ejemplo (aiblockweb.com) son referencia de proyecto: en tu .env usa IP/dominio real de cada entorno.
#
# Local / desarrollo (ENVIRONMENT=development, build debug):
#   APP_LINK_BASE_LOCAL=http://192.168.27.12
#   (añade puerto si aplica, ej. :8000 o :5173; HTTPS solo si lo tienes en LAN)
#
# Servidor de pruebas (ENVIRONMENT=staging o test) — definir DNS cuando exista, p. ej.:
#   APP_LINK_BASE_STAGING=https://test.eats.aiblockweb.com
#
# Producción (ENVIRONMENT=production o build release):
#   APP_LINK_BASE_PROD=https://eats.aiblockweb.com
#
# Override único (cualquier entorno, ignora APP_LINK_BASE_*):
# APP_LINK_BASE=
# Alias: APP_LINK_BASE_DEV (como LOCAL), APP_LINK_BASE_TEST (como STAGING), PUBLIC_LINK_BASE (legacy)

# Debug
DEBUG_MODE=true
ENABLE_LOGGING=true

# Delivery, mapas y enlaces externos (evitar hardcode en código)
DEFAULT_DELIVERY_FEE=2.50
OSM_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
NOMINATIM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
NOMINATIM_SEARCH_URL=https://nominatim.openstreetmap.org/search
GOOGLE_MAPS_DIR_URL=https://www.google.com/maps/dir/?api=1
GOOGLE_MAPS_SEARCH_URL=https://www.google.com/maps/search/?api=1
GOOGLE_MAPS_POINT_URL=https://www.google.com/maps?q
OPENSTREETMAP_VIEW_URL=https://www.openstreetmap.org
WHATSAPP_BASE_URL=https://wa.me
